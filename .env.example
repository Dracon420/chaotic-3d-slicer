# ─────────────────────────────────────────────────────────────
#  Chaotic 3D Slicer — environment configuration (OPTIONAL)
# ─────────────────────────────────────────────────────────────
# The desktop app auto-detects everything below on launch, so a .env file is
# only needed when running the bare server (`npm start`) or to override the
# auto-detection. Copy this file to `.env` and edit.

# Ports. The phone reaches the app at http://<PC-IP>:3000 and (for the
# installable PWA) https://<PC-IP>:3443.
PORT=3000
HTTPS_PORT=3443

# Bind address — 0.0.0.0 makes it reachable from your phone on the LAN.
HOST=0.0.0.0

# ─── Slicer backend (auto-detected if omitted) ───────────────
# Full path to your slicer executable:
#SLICER_PATH=C:\Program Files\ElegooSlicer\elegoo-slicer.exe
#SLICER_PATH=C:\Program Files\OrcaSlicer\orca-slicer.exe
#SLICER_PATH=C:\Program Files\Bambu Studio\bambu-studio.exe

# ─── Default slicer presets (auto-detected if omitted) ───────
# Point these at preset JSONs saved by the slicer GUI, found under
# %APPDATA%\<Slicer>\user\default\{machine,process,filament}\
#SLICER_MACHINE_PRESET=C:\Users\YOU\AppData\Roaming\ElegooSlicer\user\default\machine\Elegoo Centauri Carbon 2 0.4 nozzle.json
#SLICER_PROCESS_PRESET=C:\Users\YOU\AppData\Roaming\ElegooSlicer\user\default\process\0.20mm Standard @Elegoo CC2 0.4 nozzle.json
#SLICER_FILAMENT_PRESET=C:\Users\YOU\AppData\Roaming\ElegooSlicer\user\default\filament\Elegoo PLA Basic @ECC2.json

# Print bed size in millimetres (Centauri Carbon = 256 × 256 × 256).
BED_SIZE_X=256
BED_SIZE_Y=256
BED_SIZE_Z=256

# Where uploads/output/certs are stored (defaults to the project folder; the
# desktop app uses the per-user AppData folder automatically).
#DATA_DIR=C:\path\to\writable\folder
